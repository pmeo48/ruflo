{
  "name": "@ruflo/polymarket-bot",
  "version": "1.0.0",
  "description": "Polymarket quantitative trading bot with 4 agents, backtesting, and web dashboard",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node --experimental-vm-modules dist/index.js",
    "dev": "npx tsx index.ts",
    "paper": "PAPER_MODE=true npx tsx index.ts",
    "backtest": "npx tsx backtesting/run-backtest.ts",
    "dashboard": "npx tsx dashboard/server.ts"
  },
  "dependencies": {
    "axios": "^1.7.0",
    "express": "^4.18.3",
    "ws": "^8.17.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.10",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0"
  }
}
