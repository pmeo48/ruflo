# ── Polymarket ─────────────────────────────────────────────────────────────
# Required for live trading only. Leave blank to run in paper mode.
POLYMARKET_API_KEY=
POLYMARKET_PRIVATE_KEY=

# ── CoinGecko ───────────────────────────────────────────────────────────────
# Optional — free tier works without a key (rate-limited to 10-30 req/min)
COINGECKO_API_KEY=
COINGECKO_DEMO_KEY=

# ── Trading ─────────────────────────────────────────────────────────────────
PAPER_MODE=true            # set to false for live trading (requires private key)
DEMO_MODE=false            # set to true to use GBM price simulator instead of live APIs
INITIAL_CAPITAL=10000      # starting portfolio size in USD
SCAN_INTERVAL_MS=60000     # how often to scan markets (ms)
SIGNAL_THRESHOLD=0.05      # minimum edge % to generate a signal (0.05 = 5%)

# ── Black-Scholes vol assumptions ───────────────────────────────────────────
VOL_BTC=0.80               # annualized BTC volatility (80%)
VOL_ETH=1.00               # annualized ETH volatility (100%)
RISK_FREE_RATE=0.05        # risk-free rate for Black-Scholes

# ── Risk Manager ────────────────────────────────────────────────────────────
KELLY_FRACTION=0.25        # fractional Kelly multiplier (0.25 = quarter-Kelly)
MAX_POSITION_PCT=0.10      # max % of portfolio per single position (10%)
MAX_DRAWDOWN_PCT=0.20      # halt trading if drawdown exceeds this (20%)
MIN_EDGE=0.05              # minimum edge to consider a trade
MAX_POSITIONS=5            # maximum concurrent open positions
SLIPPAGE_PCT=0.005         # simulated market impact (0.5%)
FEE_PCT=0.002              # Polymarket maker/taker fee estimate (0.2%)

# ── Dashboard ───────────────────────────────────────────────────────────────
DASHBOARD_PORT=3456
DASHBOARD_UPDATE_MS=5000

# ── Backtest ────────────────────────────────────────────────────────────────
BT_START=2024-01-01
BT_END=2024-12-31
BT_CAPITAL=10000
BT_THRESHOLD=0.04
BT_KELLY=0.25
BT_MAX_POS=0.10
BT_MAX_DD=0.20
